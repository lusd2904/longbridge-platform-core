LONGBRIDGE_AI_MODEL_TREND_BATCH=gpt-5.4
LONGBRIDGE_AI_MODEL_RECOMMEND_BRIEF=gpt-5.4
LONGBRIDGE_AI_MODEL_RECOMMEND_SUMMARY=gpt-5.5
LONGBRIDGE_AI_MODEL_VISION=gpt-5.4
LONGBRIDGE_AI_REASONING_EFFORT=medium
LONGBRIDGE_AI_SCAN_REASONING_EFFORT=high

