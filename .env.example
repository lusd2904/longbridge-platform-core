LONGBRIDGE_AI_API_STYLE=openai-chat-completions
LONGBRIDGE_AI_API_KEY=
LONGBRIDGE_AI_MODEL=gpt-5.5
LONGBRIDGE_AI_MODEL_SCAN_PULSE=gpt-5.4
LONGBRIDGE_AI_MODEL_SCAN_FAST=gpt-5.4
