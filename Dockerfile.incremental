FROM refactor-v2-platform:local

WORKDIR /app

# The base image already installs the longbridge CLI; no need to re-download it.
COPY requirements.services.txt requirements.test.txt ./
RUN pip install --no-cache-dir -r requirements.test.txt

COPY . .

CMD ["scripts/docker_service_entrypoint.sh", "apps/market/market-service/src"]
