# Shared native shell API base. Preferred for Android / iOS / macOS local runs.
VITE_NATIVE_API_BASE_URL=http://127.0.0.1:3100

# Optional per-platform overrides.
VITE_ANDROID_API_BASE_URL=http://10.0.2.2:3100
VITE_IOS_API_BASE_URL=http://127.0.0.1:3100
VITE_DESKTOP_API_BASE_URL=http://127.0.0.1:3100

# Electron main process can also reuse the same runtime variable.
REFV2_DESKTOP_API_BASE=http://127.0.0.1:3100
